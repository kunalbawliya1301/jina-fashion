# ─────────────────────────────────────────────────────────────────────────────
# Jina Fashion — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get from: cloud.mongodb.com → Connect → Drivers
# Format: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/jina-fashion
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/jina-fashion?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX
JWT_EXPIRES_IN=1h

# ── Single Admin Credentials ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@jinafashion.com

# Bcrypt hash of the admin password.
# Generate: node scripts/seed-admin.js
# Default password: JinaFashion@2026!
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH

# ── Email / Nodemailer SMTP Config (Gmail) ───────────────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_google_app_password
EMAIL_TO=wholesale@jinafashion.com

# ── Cloudinary ───────────────────────────────────────────────────────────────
# Get from: console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Create a SIGNED upload preset in Cloudinary dashboard named:
CLOUDINARY_UPLOAD_PRESET=jina_fashion_products

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8443,https://your-domain.vercel.app

# ── Vite (Frontend) — must be prefixed with VITE_ ───────────────────────────
# In production this is auto-handled by Vercel (same domain).
# Only set this for custom API domains.
# VITE_API_URL=https://your-domain.vercel.app/api
